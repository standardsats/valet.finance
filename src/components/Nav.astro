---
import { site } from '../data/site.ts';
const { nav } = site;
---

<header class="wrap">
  <nav class="nav">
    <a class="brand" href="#">
      <img class="logo" src="/assets/valet-icon.png" alt="Valet">
      <span class="word">{nav.brand}</span>
    </a>
    <div class="nav-links">
      {nav.links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}

      <!-- Theme switcher segmented control -->
      <div class="theme-switcher" role="group" aria-label="Color scheme">
        <button class="theme-btn" data-scheme="parchment" aria-pressed="true">Parchment</button>
        <button class="theme-btn" data-scheme="modern" aria-pressed="false">Modern</button>
        <button class="theme-btn" data-scheme="dark" aria-pressed="false">Dark</button>
      </div>

      <a class="nav-cta" href={nav.cta.href}>{nav.cta.label}</a>
    </div>
  </nav>
</header>
