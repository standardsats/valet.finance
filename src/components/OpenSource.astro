---
import { ossSection } from '../data/opensource.ts';
---

<section id="opensource" class="wrap oss">
  <h2 class="section">{ossSection.heading}</h2>

  <div class="oss-card">
    <div>
      <p>{ossSection.body}</p>
      <div class="oss-stats">
        {ossSection.stats.map((stat) => (
          <div>
            <b>{stat.value}</b>
            {stat.label}
          </div>
        ))}
      </div>
      <div class="cta-row" style="margin-top: 32px;">
        <a class="btn btn-primary" href={ossSection.cta.primary.href} id="download">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-4a3 3 0 0 0-1-2.3c3-.4 6-1.5 6-7a5 5 0 0 0-1.4-3.6 5 5 0 0 0-.1-3.6S18.7 1 16 2.8a13 13 0 0 0-7 0C6.3 1 5 1.4 5 1.4A5 5 0 0 0 5 5a5 5 0 0 0-1.5 3.6c0 5.5 3 6.6 6 7a3 3 0 0 0-1 2.3v4"/>
          </svg>
          {ossSection.cta.primary.label}
        </a>
        <a class="btn btn-secondary" href={ossSection.cta.secondary.href}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 8h10M7 12h10M7 16h6"/>
            <rect x="3" y="3" width="18" height="18" rx="2"/>
          </svg>
          {ossSection.cta.secondary.label}
        </a>
      </div>
    </div>

    <div class="repo-block" aria-hidden="true">
      {ossSection.repoBlock.lines.map((line) => {
        if (line.type === 'cmd') {
          return <div><span class="pf">{line.prefix}</span> {line.text}</div>;
        }
        if (line.type === 'cmt') {
          return <div><span class="cmt">{line.text}</span></div>;
        }
        if (line.type === 'hash') {
          return (
            <div>
              <span class="br">{line.hash}</span>{' '}
              <span class="ok">{line.ok}</span>
            </div>
          );
        }
        if (line.type === 'meta') {
          return (
            <div>
              <span class="cmt">{line.label}</span>{' '}
              <span class="br">{line.value}</span>
            </div>
          );
        }
        return <div>&nbsp;</div>;
      })}
    </div>
  </div>
</section>
