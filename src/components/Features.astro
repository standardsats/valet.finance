---
import { featuresSection, features } from '../data/features.ts';

// Icon SVG paths keyed by feature number (01–05)
const icons: Record<string, string> = {
  '01': '<rect x="3" y="3" width="11" height="11" rx="1.5"/><rect x="18" y="3" width="11" height="11" rx="1.5"/><rect x="3" y="18" width="11" height="11" rx="1.5"/><rect x="18" y="18" width="11" height="11" rx="1.5"/><path d="M21.5 21.5l4 4M25.5 21.5l-4 4"/>',
  '02': '<circle cx="6" cy="16" r="3"/><circle cx="26" cy="16" r="3"/><path d="M9 16h14"/><path d="M16 9l-3 7 3 0-1 7 5-9-3 0 2-5z" fill="currentColor" stroke="none"/>',
  '03': '<path d="M10 14V9a6 6 0 1 1 12 0v5"/><rect x="6" y="14" width="20" height="14" rx="2"/>',
  '04': '<circle cx="16" cy="16" r="12"/><path d="M4 16h24M16 4a18 18 0 0 1 0 24M16 4a18 18 0 0 0 0 24"/>',
  '05': '<path d="M6 10h20v16a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2z"/><path d="M11 10V6a5 5 0 0 1 10 0v4"/><path d="M16 16v6"/><path d="m13 19 3 3 3-3"/>',
};

// UTXO grid pattern: 'on' | 'gold' | '' for 16 cells (two rows of 8)
const utxoPattern = ['on','','gold','','on','','','gold','','on','','','','gold','on',''];

function featClass(num: string): string {
  const n = num.split('/')[0].trim();
  return `feat feat-${parseInt(n, 10)}`;
}
---

<section id="features" class="wrap features">
  <h2 class="section">{featuresSection.heading}</h2>
  <p class="lede" style="margin-top: 24px; max-width: 60ch;">
    {featuresSection.lede}
  </p>

  <div class="feat-grid">
    {features.map((feat) => {
      const iconKey = feat.num.split('/')[0].trim().replace(/^0/, '');
      const paddedKey = feat.num.split('/')[0].trim().slice(-2).padStart(2,'0');
      const iconContent = icons[paddedKey] ?? icons[iconKey] ?? '';
      return (
        <div class={featClass(feat.num)}>
          <span class="num">{feat.num}</span>
          <svg class="ic" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" set:html={iconContent} />
          <h3>{feat.title}</h3>
          <p>{feat.body}</p>

          {feat.viz === 'utxo' && (
            <div class="utxo-grid" aria-hidden="true">
              {utxoPattern.map((state) => (
                <div class={`utxo${state ? ` ${state}` : ''}`}></div>
              ))}
            </div>
          )}

          {feat.viz === 'channels' && feat.channels && (
            <div class="channel-viz" aria-hidden="true">
              {feat.channels.map((ch) => (
                <div class="channel-row">
                  <span>{ch.peer}</span>
                  <div class="channel-bar">
                    <i style={`width:${ch.fill}%`}></i>
                  </div>
                  <span class="amt">{ch.amount}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      );
    })}
  </div>
</section>
