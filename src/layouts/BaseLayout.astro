---
import { site } from '../data/site.ts';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.title,
  description = site.description,
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/png" href="/assets/valet-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Apply saved theme before first paint to avoid flash -->
  <script is:inline>
    (function () {
      var saved = localStorage.getItem('valet-scheme');
      if (saved && saved !== 'parchment') {
        document.documentElement.setAttribute('data-scheme', saved);
      }
      var orn = localStorage.getItem('valet-orn') || 'minimal';
      document.documentElement.setAttribute('data-orn', orn);
    })();
  </script>
</head>
<body>

<!-- SVG symbol defs -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <symbol id="orn-corner" viewBox="0 0 80 80">
      <g fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round">
        <path d="M4 4 L4 28 M4 4 L28 4"/>
        <path d="M4 38 Q14 38 14 28 Q14 18 24 18 Q24 8 14 8"/>
        <circle cx="14" cy="28" r="1.2" fill="currentColor"/>
        <circle cx="24" cy="18" r="1.2" fill="currentColor"/>
        <path d="M40 4 Q38 14 28 14"/>
      </g>
    </symbol>
    <symbol id="fleuron" viewBox="0 0 24 12">
      <g fill="currentColor">
        <circle cx="12" cy="6" r="1.4"/>
        <circle cx="4" cy="6" r="0.8" opacity="0.6"/>
        <circle cx="20" cy="6" r="0.8" opacity="0.6"/>
      </g>
      <path d="M0 6 L4 6 M20 6 L24 6 M7 6 L17 6" stroke="currentColor" stroke-width="0.6" opacity="0.5"/>
    </symbol>
  </defs>
</svg>

<slot />

<!-- Theme switcher script -->
<script>
  const schemes = ['parchment', 'modern', 'dark'] as const;
  type Scheme = typeof schemes[number];

  function applyScheme(scheme: Scheme) {
    const root = document.documentElement;
    root.setAttribute('data-scheme', scheme === 'parchment' ? '' : scheme);
    localStorage.setItem('valet-scheme', scheme);
    document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach((btn) => {
      btn.setAttribute('aria-pressed', String(btn.dataset.scheme === scheme));
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const saved = (localStorage.getItem('valet-scheme') as Scheme) || 'parchment';
    applyScheme(saved);

    document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        applyScheme(btn.dataset.scheme as Scheme);
      });
    });
  });
</script>

</body>
</html>
